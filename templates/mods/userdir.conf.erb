<IfModule mod_userdir.c>
  UserDir public_html
  UserDir disabled root

  <Directory "<%= @public_html_dir %>"> <%# nosemgrep: ruby.rails.security.audit.xss.templates.unquoted-attribute.unquoted-attribute %>
    AllowOverride <%= @allow_override %>
    Options <%= @options %>
    <Limit GET POST OPTIONS>
	Require all granted
    </Limit>
    <LimitExcept GET POST OPTIONS>
	Require all denied
    </LimitExcept>
  </Directory>
</IfModule>
